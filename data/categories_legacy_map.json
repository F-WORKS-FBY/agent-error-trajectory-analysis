  "_legacy_audit": {
    "comment": "以下为历史词表定义,仅供审计,不再作为当前标注词表。",
    "legacy_to_v2": {
      "wrong_tool_arg": ["C2_wrong_arguments"],
      "ignored_constraint": ["A3_constraint_violation"],
      "hallucinated_fact": ["B1_hallucination"],
      "wrong_handoff": ["D1_wrong_handoff"],
      "premature_completion": ["E2_premature_completion"],
      "misread_tool_result": ["B2_observation_misread"],
      "planning_error": ["A2_planning_flaw", "A1_intent_misread"],
      "verification_oversight": ["E1_verification_oversight"],
      "tool_failure": ["C3_tool_failure"],
      "unclear_instruction": ["F2_underspecified_input", "A1_intent_misread"]

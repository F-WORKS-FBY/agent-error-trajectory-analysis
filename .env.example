# 复制为 .env 并填入你的配置:  cp .env.example .env
# 或直接 export 到环境变量。三个变量适配任意 OpenAI 兼容服务。

# 必填:API key
LLM_API_KEY=sk-your-key-here

# 选填:服务地址与模型(默认是 DeepSeek)
# 注意:base_url 到 /v1 即可(如 https://api.siliconflow.cn/v1),**不要**带 /chat/completions。
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro

# 向后兼容:也接受 DEEPSEEK_API_KEY / DEEPSEEK_BASE_URL / DEEPSEEK_MODEL(LLM_* 优先)。
# 示例(换成 OpenAI):
#   LLM_API_KEY=sk-...
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o
# 示例(SiliconFlow):
#   LLM_BASE_URL=https://api.siliconflow.cn/v1
#   LLM_MODEL=deepseek-ai/DeepSeek-V3

# 选填:每阶段独立模型/端点/key(可跨 provider 混用)。不设则回退到上面的全局值。
# stage: local=局部摘要(调用量最大)、phase=阶段聚合、root=根因判定(最需推理)。
#   LLM_MODEL_LOCAL=...    LLM_BASE_URL_LOCAL=...    LLM_API_KEY_LOCAL=...
#   LLM_MODEL_PHASE=...    LLM_BASE_URL_PHASE=...    LLM_API_KEY_PHASE=...
#   LLM_MODEL_ROOT=...     LLM_BASE_URL_ROOT=...     LLM_API_KEY_ROOT=...

# 选填:thinking 私有参数风格。留空=按 base_url 推断(deepseek.com→deepseek,其余→none=不注入)。
# 指向 DeepSeek 官方推理端点时可设 deepseek;SiliconFlow 混合推理模型可设 siliconflow。
#   LLM_THINKING_STYLE=deepseek

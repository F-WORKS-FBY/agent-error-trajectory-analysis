# 复制为 .env 并填入你的配置:  cp .env.example .env
# 或直接 export 到环境变量。三个变量适配任意 OpenAI 兼容服务。

# 必填:API key
LLM_API_KEY=sk-your-key-here

# 选填:服务地址与模型(默认是 DeepSeek)
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro

# 向后兼容:也接受 DEEPSEEK_API_KEY / DEEPSEEK_BASE_URL / DEEPSEEK_MODEL(LLM_* 优先)。
# 示例(换成 OpenAI):
#   LLM_API_KEY=sk-...
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o
